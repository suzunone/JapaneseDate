{
  "name": "japanese-date/japanese-date",
  "description": "日本の暦、祝日を取り扱うライブラリ",
  "type": "library",
  "license": "BSD-2-Clause-FreeBSD",
  "authors": [
    {
      "name": "Suzunone",
      "email": "suzunone.eleven@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.0",
    "nesbot/carbon": "^2.0",
    "ext-calendar": "*",
    "ext-json": "*",
    "symfony/polyfill-mbstring": ">=1.20",
    "symfony/polyfill-ctype": ">=1.20"
  },
  "suggest": {
    "ext-bcmath": "ELP200アルゴリズムを使用する場合に必要"
  },
  "require-dev": {
    "phpunit/phpunit": "^7.5.20 || ^8.5.26 || ^9.5.20",
    "mockery/mockery": "*",
    "fzaninotto/faker": "*",
    "friendsofphp/php-cs-fixer": "^3.75",
    "rector/rector": "^2.4",
    "brianium/paratest": "^6.0"
  },
  "autoload": {
    "psr-4": {
      "JapaneseDate\\": "src"
    }
  },
  "scripts": {
    "cs-fix": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php",
    "doc": "sh doc.sh",
    "rector": "vendor/bin/rector",
    "test": [
      "Composer\\Config::disableProcessTimeout",
      "paratest --configuration phpunit.xml --processes=20 --functional --exclude-group large --exclude-group long-running"
    ],
    "test:all": [
      "Composer\\Config::disableProcessTimeout",
      "paratest --configuration phpunit.xml --processes=20 --functional"
    ],
    "test:serial": [
      "Composer\\Config::disableProcessTimeout",
      "phpunit --configuration phpunit.coverage.xml"
    ],
    "generate-fixture": [
      "tests/scripts/generate_fixture.php 2025 &",
      "tests/scripts/generate_fixture.php 2024 &",
      "tests/scripts/generate_fixture.php 2023 &",
      "tests/scripts/generate_fixture.php 2022 &",
      "tests/scripts/generate_fixture.php 2021 &",
      "tests/scripts/generate_fixture.php 2020 &",
      "tests/scripts/generate_fixture.php 2019 &",
      "tests/scripts/generate_fixture.php 2018 &",
      "tests/scripts/generate_fixture.php 2017 &",
      "tests/scripts/generate_fixture.php 2016 &",
      "tests/scripts/generate_fixture.php 2015 &",
      "tests/scripts/generate_fixture.php 2014 &",
      "tests/scripts/generate_fixture.php 2013 &",
      "tests/scripts/generate_fixture.php 2012 &",
      "tests/scripts/generate_fixture.php 2011 &"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\JapaneseDate\\": "tests/Tests/JapaneseDate"
    }
  }
}
